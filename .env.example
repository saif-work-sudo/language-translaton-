# Supabase Configuration
# Get these from your Supabase Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# LibreTranslate API (Optional - for real translations)
# Use https://libretranslate.de or your own self-hosted instance
NEXT_PUBLIC_LIBRE_TRANSLATE_URL=https://libretranslate.de
NEXT_PUBLIC_LIBRE_API_KEY=your-api-key-if-needed

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
